# 금융감독원 금융상품한눈에 API 키 (대출 비교용)
# 발급: https://finlife.fss.or.kr → 오픈API 인증키 신청 (무료, 즉시)
FSS_FINLIFE_KEY=

# (선택) 국토부 실거래가 data.go.kr 직결용 키 — realprice_search.py --source molit 일 때만 필요.
# 발급: https://www.data.go.kr → "아파트 매매 실거래가 상세 자료" 활용신청.
# 비워두면 기본 경로(k-skill-proxy, 키 불필요)를 씁니다.
DATA_GO_KR_KEY=

# (선택) 실거래 프록시 base URL override. 비워두면 공개 프록시 사용.
# KSKILL_PROXY_BASE_URL=https://k-skill-proxy.nomadamas.org
